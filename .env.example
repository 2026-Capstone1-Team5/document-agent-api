POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=document_agent_api
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/document_agent_api
CORS_ALLOW_ORIGINS=https://document-agent-web.vercel.app
AUTH_SECRET_KEY=dev-only-change-this-key
AUTH_ACCESS_TOKEN_TTL_SECONDS=1800

STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=data/storage
STORAGE_BUCKET=
STORAGE_R2_ENDPOINT=
STORAGE_R2_ACCESS_KEY_ID=
STORAGE_R2_SECRET_ACCESS_KEY=
STORAGE_R2_REGION=auto

DOCUMENT_AGENT_API_TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/document_agent_api_test
