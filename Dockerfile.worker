FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV UV_LINK_MODE=copy
ENV PIP_NO_CACHE_DIR=1
ENV HF_HOME=/opt/mineru-cache/huggingface
ENV TRANSFORMERS_CACHE=/opt/mineru-cache/huggingface/transformers
ENV HUGGINGFACE_HUB_CACHE=/opt/mineru-cache/huggingface/hub
ENV MINERU_MODEL_SOURCE=huggingface
ENV MINERU_DEVICE_MODE=cpu

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        fontconfig \
        fonts-noto-cjk \
        fonts-noto-core \
        libgl1 \
        libglib2.0-0 \
        poppler-utils \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock ./

RUN uv sync --frozen --no-dev

# document-ai runtime dependencies (CPU) installed into the uv-managed venv.
RUN uv pip install --python .venv/bin/python \
        --index-url https://download.pytorch.org/whl/cpu \
        "torch==2.6.0+cpu" \
        "torchvision==0.21.0+cpu" \
    && uv pip install --python .venv/bin/python \
        "mineru[pipeline]==2.7.6" \
        "pymupdf>=1.24.0" \
        "pillow>=10.0.0"

COPY src ./src
COPY migrations ./migrations
COPY alembic.ini ./
COPY vendor ./vendor

# Preload MinerU/Hugging Face models during image build to avoid first-run downloads.
RUN mkdir -p "$HF_HOME" /tmp/model-warmup \
    && .venv/bin/python -c "import fitz; from pathlib import Path; p=Path('/tmp/model-warmup/warmup.pdf'); p.parent.mkdir(parents=True, exist_ok=True); d=fitz.open(); pg=d.new_page(); pg.insert_text((72,72),'document-ai model warmup'); d.save(p); d.close()" \
    && .venv/bin/python -m src.worker.document_ai_entrypoint \
        "/tmp/model-warmup/warmup.pdf" \
        "/tmp/model-warmup/out" \
        --parse-script "/app/vendor/document-ai/scripts/parse_document.py" \
        --language en \
    && rm -rf /tmp/model-warmup

CMD ["/app/.venv/bin/python", "-m", "src.worker.main"]
